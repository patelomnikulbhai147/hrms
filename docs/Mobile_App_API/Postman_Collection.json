{
  "info": {
    "name": "HRMS Mobile App API (v1)",
    "_postman_id": "hrms-mobile-app-v1",
    "description": "Set {{baseUrl}}. Login + Verify auto-capture session and tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "sessionId",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "[Authentication] Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const d=pm.response.json().data||{};",
              "if(d.sessionId)pm.collectionVariables.set('sessionId',d.sessionId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/app/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "app",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mobile\": \"9876543210\"\n}"
        }
      }
    },
    {
      "name": "[Authentication] Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const d=pm.response.json().data||{};",
              "if(d.accessToken)pm.collectionVariables.set('accessToken',d.accessToken);",
              "if(d.refreshToken)pm.collectionVariables.set('refreshToken',d.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/app/auth/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "app",
            "auth",
            "verify-otp"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"1234\"\n}"
        }
      }
    },
