# ============================================================================
#  FRONTEND PRODUCTION ENVIRONMENT  —  copy to  .env.production  at repo root
#  on the FRONTEND EC2 before running `npm run build`.
#  cp deploy/frontend/.env.production.example .env.production
# ============================================================================

# The frontend reaches the API through the nginx reverse proxy on the SAME host,
# so this is a relative path. nginx forwards /api/* to the backend EC2:5000.
# (See deploy/frontend/nginx-hrms.conf.) This means the backend IP is NOT baked
# into the JS bundle — you can change the backend without rebuilding the frontend.
VITE_API_BASE_URL=/api

# If you ever want the browser to call the backend DIRECTLY (no nginx proxy),
# set this to the backend's public address instead, e.g.:
# VITE_API_BASE_URL=http://BACKEND_PUBLIC_IP:5000/api
# ...and set CORS_ORIGIN on the backend to the frontend origin.
