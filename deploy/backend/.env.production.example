# ============================================================================
#  BACKEND PRODUCTION ENVIRONMENT  —  copy to  backend/.env  on the backend EC2
#  cp deploy/backend/.env.production.example backend/.env   (then edit values)
#  NEVER commit the real .env (it is gitignored).
# ============================================================================

# --- Server ---------------------------------------------------------------
PORT=5000
NODE_ENV=production

# --- Database (AWS RDS for MySQL) -----------------------------------------
# Format: mysql://USER:PASSWORD@RDS_ENDPOINT:3306/DBNAME
# Get RDS_ENDPOINT from the RDS console ("Endpoint"). URL-encode special
# characters in the password (@ -> %40, : -> %3A, / -> %2F, # -> %23).
DATABASE_URL="mysql://hrms_admin:CHANGE_ME_DB_PASSWORD@your-rds-endpoint.xxxxxx.ap-south-1.rds.amazonaws.com:3306/corehrms"

# --- Authentication -------------------------------------------------------
# Generate a strong secret:  openssl rand -hex 48
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
JWT_EXPIRES_IN="12h"
JWT_REMEMBER_EXPIRES_IN="30d"
RESET_TOKEN_EXPIRES_IN="15m"

# --- CORS -----------------------------------------------------------------
# The frontend origin. With the nginx same-origin proxy this is harmless to set
# but not strictly required. Put the frontend EC2 public IP (no trailing slash).
# Comma-separate multiple origins if needed.
CORS_ORIGIN="http://FRONTEND_PUBLIC_IP"

# --- Email / OTP delivery (password reset) --------------------------------
# Fully provider-agnostic. To switch to the official HRMate mailbox later, change
# ONLY SMTP_USER, SMTP_PASS and MAIL_FROM — no code changes needed.
#
# Provider host/port quick reference:
#   Gmail / Google Workspace : smtp.gmail.com           587 (TLS) | 465 (SSL)
#     SMTP_PASS must be a 16-char App Password (not the login password).
#   Outlook / Microsoft 365  : smtp.office365.com       587 (TLS)
#   Zoho Mail                : smtp.zoho.com / .in       587 (TLS) | 465 (SSL)
#   Custom SMTP              : your-mail-host             per provider
# Rule of thumb: port 465 -> SMTP_SECURE="true"; port 587 -> SMTP_SECURE="false".
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-address@gmail.com"
SMTP_PASS="your-app-password"

# The visible sender. MAIL_FROM is preferred; SMTP_FROM still works as a fallback.
MAIL_FROM="HRMate Security <no-reply@hrmate.com>"

# Email branding (optional — sensible defaults applied if omitted).
MAIL_BRAND="HRMate"
MAIL_LOGO_URL=""                       # hosted logo image URL; blank = text wordmark
SUPPORT_EMAIL="support@hrmate.com"     # shown in the email footer
