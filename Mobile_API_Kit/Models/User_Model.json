{
  "id": "integer — User id",
  "employeeId": "string|null — official employee code (e.g. VE-AHM-001)",
  "employeeCode": "string|null — same as employeeId",
  "firstName": "string",
  "lastName": "string",
  "name": "string",
  "email": "string|null",
  "mobile": "string|null",
  "company": "Company_Model|null",
  "branch": "Branch_Model|null",
  "department": "string|null",
  "designation": "string|null",
  "role": "string — e.g. 'Employee' | 'HR' | 'Company Head' | 'Super Admin'",
  "permissions": "string[] — flat permission keys, e.g. [\"attendance.view\"]",
  "permissionMatrix": "object — { module: { action: boolean } }",
  "moduleAccess": "object — { module: boolean }",
  "profileImage": "string — URL or base64 (may be empty)",
  "themePreference": "string|null — reserved",
  "languagePreference": "string|null — reserved",
  "isFirstLogin": "boolean",
  "isPasswordCreated": "boolean",
  "_example": {
    "id": 1,
    "userId": 1,
    "employeeRecordId": 12,
    "employeeId": "VE-AHM-001",
    "employeeCode": "VE-AHM-001",
    "firstName": "Om",
    "lastName": "Patel",
    "name": "Om Patel",
    "email": "abc@gmail.com",
    "mobile": "9876543210",
    "company": {
      "id": 2,
      "name": "Vision Enterprise"
    },
    "branch": {
      "id": 5,
      "name": "Ahmedabad"
    },
    "department": "IT",
    "designation": "Developer",
    "role": "Employee",
    "permissions": [
      "attendance.view",
      "attendance.mark",
      "leave.create"
    ],
    "permissionMatrix": {
      "attendance": {
        "view": true,
        "mark": true
      },
      "leave": {
        "create": true
      }
    },
    "moduleAccess": {
      "attendance": true,
      "leave": true
    },
    "profileImage": "",
    "themePreference": null,
    "languagePreference": null,
    "isFirstLogin": false,
    "isPasswordCreated": true
  }
}
