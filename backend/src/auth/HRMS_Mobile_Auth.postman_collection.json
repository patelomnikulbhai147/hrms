{
  "info": {
    "name": "HRMS Mobile Auth (v1)",
    "_postman_id": "hrms-mobile-auth-v1",
    "description": "OTP-based mobile authentication for the HRMS Flutter app. Set {{baseUrl}} to your backend (e.g. http://localhost:5000). The login + verify-otp requests auto-capture sessionId and tokens into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "sessionId", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login (mobile / employeeId / email)",
      "event": [
        { "listen": "test", "script": { "exec": [
          "const j = pm.response.json();",
          "if (j.sessionId) pm.collectionVariables.set('sessionId', j.sessionId);",
          "if (j.devOtp) pm.collectionVariables.set('devOtp', j.devOtp);",
          "pm.test('OTP generated', () => pm.expect(j.success).to.be.true);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
        "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"9876543210\"\n}" }
      }
    },
    {
      "name": "2. Verify OTP",
      "event": [
        { "listen": "test", "script": { "exec": [
          "const j = pm.response.json();",
          "if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);",
          "if (j.refreshToken) pm.collectionVariables.set('refreshToken', j.refreshToken);",
          "pm.test('Authenticated', () => pm.expect(j.success).to.be.true);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "verify-otp"] },
        "body": { "mode": "raw", "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"otp\": \"1234\"\n}" }
      }
    },
    {
      "name": "3. Get Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
      }
    },
    {
      "name": "4. Refresh Token",
      "event": [
        { "listen": "test", "script": { "exec": [
          "const j = pm.response.json();",
          "if (j.accessToken) pm.collectionVariables.set('accessToken', j.accessToken);"
        ], "type": "text/javascript" } }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"] },
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
      }
    },
    {
      "name": "5. Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
      }
    }
  ]
}
