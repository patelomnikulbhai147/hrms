generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int        @id @default(autoincrement())
  name                 String
  email                String     @unique
  username             String     @unique
  passwordHash         String
  role                 String
  companyId            Int?
  branchId             Int?       // optional branch a management user is scoped to (for branch-context task assignment)
  accessibleCompanyIds Json       @default(dbgenerated("(JSON_ARRAY())"))
  status               String     @default("Active")
  avatar               String?    @db.LongText
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  employeeId           Int?
  permissions          Json?
  password             String?
  userId               String?
  lastLoginAt          DateTime?
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        Int   @id @default(autoincrement())
  userId    Int
  email     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
}

model LoginAudit {
  id        Int   @id @default(autoincrement())
  userId    Int?
  email     String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

model Company {
  id                          Int              @id @default(autoincrement())
  name                        String
  domain                      String?
  adminName                   String?
  adminEmail                  String?
  phone                       String?
  industry                    String?
  status                      String           @default("Active")
  accountStatus               String           @default("Active")
  paymentStatus               String           @default("Paid")
  plan                        String           @default("Starter")
  employeeCount               Int              @default(0)
  joinDate                    DateTime         @default(now())
  logo                        String?          @db.LongText
  logoImage                   String?          @db.LongText
  isHeadOffice                Boolean          @default(true)
  parentCompanyId             Int?
  offboardingState            Json?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  basicPercent                Float?
  esicRate                    Float?
  overtimeRate                Float?
  pfRate                      Float?
  primaryColor                String?
  profTaxRate                 Float?
  themeStyle                  String?
  // ── Company branding (managed via Settings → Company Profile & Branding) ──
  shortName                   String?
  tagline                     String?
  website                     String?
  contactEmail                String?
  contactNumber               String?
  address                     String?  @db.Text
  description                 String?  @db.Text
  // ── Company profile identity (Settings → Company Profile & Branding) ──
  companyCode                 String?
  registrationNumber          String?
  panNumber                   String?
  cinNumber                   String?
  city                        String?
  state                       String?
  pincode                     String?
  emailSignature              String?  @db.Text
  // Digital assets (base64 data URLs)
  faviconImage                String?  @db.LongText
  stampImage                  String?  @db.LongText
  digitalSignatureImage       String?  @db.LongText
  activeHrUsers               Int?
  billingAddress              String?
  billingCycle                String?
  billingIncluded             Boolean?
  branchCode                  String?
  branchLicenseActive         Boolean?
  branchLicenseStatus         String?
  branchName                  String?
  branchPortalActive          Boolean?
  branchPriceAddon            Float?
  branchRenewalDate           String?
  companyIndustry             String?
  customDepartments           Json             @default(dbgenerated("(JSON_ARRAY())"))
  departmentTemplateType      String?
  employeeCapacity            Int?
  footerText                  String?
  gstNumber                   String?
  headerText                  String?
  inheritParentDepartments    Boolean?
  licensedEmployeeLimit       Int?
  monthlyBranchCost           Float?
  monthlyUsage                Float?
  payrollLoad                 Float?
  priceMonthly                Float?
  priceYearly                 Float?
  purchasedAdditionalBranches Int?
  signatureText               String?
  storageUsed                 String?
  subscriptionPrice           Float?
  isArchived                  Boolean          @default(false)
  attendances                 Attendance[]
  branches                    Branch[]
  companyPayrolls             CompanyPayroll[]
  documents                   Document[]
  employees                   Employee[]
  leaveRequests               LeaveRequest[]
  paymentRecords              PaymentRecord[]
  payrolls                    Payroll[]
  overtimes                   Overtime[]
  shifts                      Shift[]
  leaveCreditConfigs          LeaveCreditConfig[]
  leaveBalances               LeaveBalance[]
  attendanceSummaries         AttendanceSummary[]
  attendanceDevices           AttendanceDevice[]
}

model Branch {
  id               Int             @id @default(autoincrement())
  companyId        Int
  branchNo         Int?
  branchName       String
  location         String?
  headcount        Int             @default(0)
  status           String          @default("Active")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isArchived       Boolean         @default(false)
  adminEmail       String?
  adminName        String?
  basicPercent     Float           @default(50)
  branchCode       String?
  email            String?
  employeeCapacity Int             @default(200)
  esicRate         Float           @default(3.25)
  overtimeRate     Float           @default(1.5)
  pfRate           Float           @default(12)
  phone            String?
  profTaxRate      Float           @default(200)
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchPayrolls   BranchPayroll[]
  employees        Employee[]
  attendanceDevices AttendanceDevice[]
}

// ── Biometric attendance devices (Phase 1: registry only) ───────────────────
// Registers physical attendance devices per company/branch. This table does NOT
// store attendance punches — the existing `attendance` table remains the single
// source of attendance truth. No device connectivity or sync logic lives here.
model AttendanceDevice {
  id           Int       @id @default(autoincrement())
  companyId    Int
  branchId     Int?
  deviceName   String
  deviceIp     String?
  port         Int?
  serialNumber String?
  deviceType   String?
  status       String    @default("ACTIVE") // ACTIVE / INACTIVE
  lastSync     DateTime?
  lastTestAt         DateTime?  // Phase 5: last "Test Connection" run
  lastTestStatus     String?    // CONNECTED / FAILED
  lastTestResponseMs Int?       // round-trip connect time in ms
  // ── Phase 2: device configuration storage (vendor-driven; no sync yet) ──
  attendanceVendor String?   // vendor name; validated against the attendance_vendors registry (NOT a hardcoded list)
  apiBaseUrl       String?   @db.Text // per-device API base URL (overrides the vendor default; fully configurable)
  corporateId      String?   // vendor portal corporate / company id
  apiUsername      String?   // vendor API username
  apiPassword      String?   @db.Text // vendor API password — stored ENCRYPTED (AES-256-GCM), never returned in plaintext
  deviceLocation   String?   // free-text physical location
  syncEnabled      Boolean   @default(false) // future-sync opt-in flag (no effect yet)
  syncIntervalMinutes Int?   // optional per-device sync cadence (config only; no scheduler yet)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([branchId])
  @@map("attendance_devices")
}

// ── Attendance vendor registry ──────────────────────────────────────────────
// Configurable catalog of attendance API vendors. New vendors (eSSL, Matrix,
// ZKTeco, BioMax, …) are added as ROWS here (via the Super-Admin vendor API or a
// seed) — NOT by changing code. Per-vendor defaults (base URL, auth type, free
// settings JSON) live here so nothing vendor-specific is hardcoded in the app.
model AttendanceVendor {
  id             Int      @id @default(autoincrement())
  name           String   @unique          // canonical name, e.g. "E-TimeOffice"
  displayName    String?                    // friendly label, e.g. "E-TimeOffice (Pulpit Mobility)"
  defaultBaseUrl String?  @db.Text          // default API base URL (editable; used to prefill a device)
  authType       String?                    // BASIC / TOKEN / NONE — informational
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  settings       String?  @db.LongText      // arbitrary JSON for vendor-specific options (no code change needed)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("attendance_vendors")
}

// ── Pre-Phase 5 safety: attendance import log ───────────────────────────────
// One row per evaluated punch recording the matching VERDICT. This is an audit
// trail only — it is NOT the attendance table and never marks anyone present.
model AttendanceImportLog {
  id            Int      @id @default(autoincrement())
  companyId     Int
  deviceId      Int?
  biometricCode String?
  employeeId    Int?      // resolved Employee.id (null when unmatched)
  employeeCode  String?   // snapshot of the business Employee ID, for readability
  employeeName  String?   // snapshot
  punchTime     String?
  status        String    // MATCHED / NO_BIOMETRIC_CODE / UNMATCHED / DUPLICATE_CODE
  message       String?   @db.Text
  importDate    DateTime  @default(now())

  @@index([companyId])
  @@index([status])
  @@map("attendance_import_logs")
}

// ── Pre-Phase 5 safety: unmatched attendance queue ──────────────────────────
// Punches that could NOT be safely matched (blank code / no match / duplicate
// code) are parked here for an admin to resolve. No attendance is created.
model UnmatchedAttendance {
  id            Int      @id @default(autoincrement())
  companyId     Int
  deviceId      Int?
  biometricCode String?
  punchTime     String?
  reason        String    // NO_BIOMETRIC_CODE / UNMATCHED / DUPLICATE_CODE
  message       String?   @db.Text
  rawPayload    String?   @db.Text
  resolved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([resolved])
  @@map("unmatched_attendance_queue")
}

// ── Bonus Management — separate bonus transaction system ─────────────────────
// Deliberately decoupled from the Employee table: bonus changes yearly, supports
// multiple types, must keep full audit history, and integrates with payroll.

// Per-company, per-financial-year bonus rules (template the cycles use).
model BonusConfiguration {
  id                   Int      @id @default(autoincrement())
  companyId            Int
  bonusType            String   // Statutory / Festival / Performance / Ex-Gratia / Special
  financialYear        String   // e.g. "2024-2025"
  minBonusPercent      Float    @default(8.33)
  maxBonusPercent      Float    @default(20)
  salaryCeiling        Float?   // statutory wage ceiling (e.g. 21000)
  minWorkingDays       Int      @default(30)
  includeLeaveDays     Boolean  @default(true)
  includeOvertime      Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, financialYear])
  @@map("bonus_configurations")
}

// A bonus run for a company / FY / type. Drives the approval workflow.
model BonusCycle {
  id                   Int      @id @default(autoincrement())
  companyId            Int
  configId             Int?
  name                 String
  bonusType            String
  financialYear        String
  status               String   @default("Draft") // Draft / Calculated / Approved / Paid / Cancelled
  totalAmount          Float    @default(0)
  employeeCount        Int      @default(0)
  generatedBy          Int?
  approvedBy           Int?
  releasedBy           Int?
  generatedAt          DateTime?
  approvedAt           DateTime?
  paidAt               DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("bonus_cycles")
}

// Per-employee eligibility within a cycle.
model BonusEligibility {
  id                   Int      @id @default(autoincrement())
  cycleId              Int
  companyId            Int
  employeeId           Int
  workingDays          Int      @default(0)
  eligibilityStatus    String   @default("Pending Verification") // Eligible / Not Eligible / Pending Verification
  reason               String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([cycleId])
  @@index([companyId])
  @@map("bonus_eligibility")
}

// Per-employee calculated bonus within a cycle (supports manual override).
model BonusCalculation {
  id                   Int      @id @default(autoincrement())
  cycleId              Int
  companyId            Int
  employeeId           Int
  eligibleSalary       Float    @default(0)
  bonusPercent         Float    @default(0)
  bonusAmount          Float    @default(0)
  isManualOverride     Boolean  @default(false)
  overrideBy           Int?
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([cycleId])
  @@index([companyId])
  @@map("bonus_calculations")
}

// Payment records (release stage).
model BonusPayment {
  id                   Int      @id @default(autoincrement())
  cycleId              Int
  companyId            Int
  employeeId           Int
  amount               Float    @default(0)
  paymentDate          DateTime?
  paymentMode          String?  // Bank Transfer / Cash / Cheque
  reference            String?
  status               String   @default("Pending") // Pending / Paid / Failed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([cycleId])
  @@index([companyId])
  @@map("bonus_payments")
}

// Immutable audit trail for every bonus action.
model BonusAuditLog {
  id                   Int      @id @default(autoincrement())
  companyId            Int
  cycleId              Int?
  entityType           String   // CONFIGURATION / CYCLE / ELIGIBILITY / CALCULATION / PAYMENT
  entityId             Int?
  action               String   // CREATE / UPDATE / DELETE / GENERATE / APPROVE / RELEASE / CANCEL
  performedBy          Int?
  performedByName      String?
  details              String?  @db.Text
  createdAt            DateTime @default(now())

  @@index([companyId])
  @@index([cycleId])
  @@map("bonus_audit_logs")
}

// ── Location master list (custom states/cities saved for reuse) ──────────────
// Backs the creatable State/City comboboxes: custom entries are stored here so
// they appear in the dropdown for everyone next time. State & City are
// independent — there is intentionally no state→city relationship.
model LocationMaster {
  id        Int      @id @default(autoincrement())
  type      String   // 'city' | 'state'
  name      String
  createdAt DateTime @default(now())

  @@unique([type, name])
  @@index([type])
  @@map("location_masters")
}

// ── Geography masters: Country → State → City ───────────────────────────────
// Relational reference data for the Employee Personal-Info location fields and the
// Nationality field. Seeded from the bundled dataset (India's states/UTs + cities,
// and the international country list) and extended at runtime with custom entries:
// custom cities are linked to their state, so a state's city dropdown only ever
// shows that state's cities. `isCustom` marks user-added rows. Existing free-text
// state/city/nationality values on employees are unaffected (no FK on Employee).
model CountryMaster {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  isCustom  Boolean       @default(false)
  createdAt DateTime      @default(now())
  states    StateMaster[]

  @@map("country_masters")
}

model StateMaster {
  id        Int           @id @default(autoincrement())
  name      String
  countryId Int
  country   CountryMaster @relation(fields: [countryId], references: [id], onDelete: Cascade)
  isCustom  Boolean       @default(false)
  createdAt DateTime      @default(now())
  cities    CityMaster[]

  @@unique([countryId, name])
  @@index([countryId])
  @@map("state_masters")
}

model CityMaster {
  id        Int         @id @default(autoincrement())
  name      String
  stateId   Int
  state     StateMaster @relation(fields: [stateId], references: [id], onDelete: Cascade)
  isCustom  Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@unique([stateId, name])
  @@index([stateId])
  @@map("city_masters")
}

// ── Government compliance report audit trail ─────────────────────────────────
// Every generate/download of a statutory report is logged here (who, what,
// filters used, when) for the compliance audit trail.
model ComplianceReportLog {
  id              Int      @id @default(autoincrement())
  companyId       Int
  reportKey       String
  reportName      String
  action          String   // GENERATE / DOWNLOAD
  format          String?  // PDF / EXCEL (for downloads)
  filters         String?  @db.Text
  rowCount        Int      @default(0)
  performedBy     Int?
  performedByName String?
  createdAt       DateTime @default(now())

  @@index([companyId])
  @@index([reportKey])
  @@map("compliance_report_logs")
}

// ── Raw device push log (Phase 6: ADMS-style receiver, DEBUG only) ───────────
// Captures every inbound request from an attendance device exactly as received.
// This is a debug/inspection table — it is NOT the attendance table and is never
// used to mark anyone present. No FK to a device (the pusher may be unidentified).
model DevicePushLog {
  id               Int      @id @default(autoincrement())
  receivedAt       DateTime @default(now())
  deviceId         Int?
  deviceIp         String?
  method           String?
  path             String?  @db.Text
  contentType      String?
  headers          String?  @db.LongText
  query            String?  @db.Text
  rawPayload       String?  @db.LongText
  userId           String?
  biometricId      String?
  punchTime        String?
  punchType        String?
  // Phase 7A — eTimeOffice XML-over-TCP handshake fields + the exact ACK we sent
  terminalType     String?
  deviceUid        String?
  deviceSerialNo   String?
  terminalId       String?
  responsePayload  String?  @db.LongText
  processingResult String?  // e.g. "HANDSHAKE_ACK_v1 (no attendance created)"
  createdAt        DateTime @default(now())

  @@index([receivedAt])
  @@map("device_push_logs")
}

model Employee {
  id                Int            @id @default(autoincrement())
  employeeId        String         @unique
  legacyEmployeeId  String?
  companyId         Int
  branchId          Int?
  shiftId           Int?
  biometricId       String?        @db.VarChar(50)
  name              String
  firstName         String?
  lastName          String?
  email             String
  phone             String?
  department        String
  designation       String
  role              String         @default("Staff")
  status            String         @default("Active")
  joinDate          DateTime
  exitDate          DateTime?
  exitReason        String?
  location          String?
  avatar            String?        @db.LongText
  salary            Float          @default(0)
  manager           String?
  pan               String?
  aadhaar           String?
  uan               String?
  pfNumber          String?
  esiNumber         String?
  bankName          String?
  accountNumber     String?
  ifsc              String?
  // ── IFSC-resolved bank details (auto-fetched from the IFSC code) ──
  accountHolderName String?
  bankBranch        String?
  bankAddress       String?        @db.Text
  bankCity          String?
  bankDistrict      String?
  bankState         String?
  offboardingState  Json?
  employmentHistory Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  documents         Json?
  aadhaarName       String?
  aadhaarUpload     String?        @db.LongText
  branchLocation    String?
  category          String?
  dob               String?
  emergencyContact  String?
  employmentType    String?
  fatherSpouseName  String?
  gender            String?
  maritalStatus     String?
  middleName        String?
  nationality       String?
  state             String?        // employee home state (Personal Info)
  city              String?        // employee home city (dependent on state)
  panUpload         String?        @db.LongText
  permanentAddress  String?        @db.Text
  photoUpload       String?        @db.LongText
  presentAddress    String?        @db.Text
  relationType      String?
  signatureUpload   String?        @db.LongText
  attendance        Attendance[]
  branch            Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shift             Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  leaveRequests     LeaveRequest[]
  payroll           Payroll[]
  overtimes         Overtime[]
  leaveBalances     LeaveBalance[]
  attendanceSummaries AttendanceSummary[]
}

model Payroll {
  id               Int   @id @default(autoincrement())
  companyId        Int      @default(1)
  employeeId       Int
  employeeName     String   @default("Unknown")
  department       String   @default("General")
  month            String
  year             Int      @default(2026)
  basicSalary      Float    @default(0)
  allowances       Float    @default(0)
  deductions       Float    @default(0)
  netSalary        Float    @default(0)
  payrollStatus    String   @default("draft")
  paymentStatus    String   @default("pending")
  payslipGenerated Boolean  @default(false)
  // ── Attendance-derived figures (single source of truth = AttendanceSummary) ──
  presentDays      Float     @default(0)
  clDays           Float     @default(0)
  plDays           Float     @default(0)
  slDays           Float     @default(0)
  lwpDays          Float     @default(0)
  halfDays         Float     @default(0)
  otHours          Float     @default(0)
  payableDays      Float     @default(0)
  isOutdated       Boolean   @default(false)
  summarySyncedAt  DateTime?
  processedOn      String?
  paymentDate      String?
  dueDate          String?
  paymentMethod    String?
  paidBy           String?
  bonus            Float?
  tax              Float?
  notes            String?
  companyPayrollId String?
  branchPayrollId  String?
  // ── Payslip lifecycle tracking (audit history) ──
  payslipFileName  String?
  generatedAt      DateTime?
  downloadedAt     DateTime?
  downloadCount    Int       @default(0)
  emailSentAt      DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  lockedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year, companyId])
}

model CompanyPayroll {
  id                 Int   @id @default(autoincrement())
  companyId          Int
  payrollMonth       String   @map("payroll_month")
  payrollYear        Int      @map("payroll_year")
  totalEmployees     Int      @map("total_employees")
  processedEmployees Int      @map("processed_employees")
  pendingEmployees   Int      @map("pending_employees")
  totalAmount        Float    @map("total_amount")
  status             String   @default("Pending")
  generatedBy        String   @map("generated_by")
  generatedAt        DateTime @default(now()) @map("generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, payrollMonth, payrollYear])
}

model BranchPayroll {
  id                 Int   @id @default(autoincrement())
  branchId           Int      @map("branch_id")
  companyId          Int      @map("company_id")
  payrollMonth       String   @map("payroll_month")
  payrollYear        Int      @map("payroll_year")
  totalEmployees     Int      @map("total_employees")
  processedEmployees Int      @map("processed_employees")
  pendingEmployees   Int      @map("pending_employees")
  totalAmount        Float    @map("total_amount")
  status             String   @default("Pending")
  generatedBy        String   @map("generated_by")
  generatedAt        DateTime @default(now()) @map("generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  branch             Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, payrollMonth, payrollYear])
}

model Attendance {
  id           Int   @id @default(autoincrement())
  companyId    Int      @default(1)
  employeeId   Int
  employeeName String   @default("Unknown")
  department   String   @default("General")
  branch       String?
  date         String   @default("2026-05-20")
  clockIn      String   @default("09:00")
  clockOut     String   @default("18:00")
  status       String   @default("Present")
  hoursWorked  Float    @default(8)
  flags        Json     @default(dbgenerated("(JSON_ARRAY())"))
  leaveType    String?
  shift        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Single source of truth: exactly ONE attendance row per employee per date.
  // Prevents the duplicate rows that caused edits to "revert" after refresh.
  @@unique([employeeId, date])
}

model Overtime {
  id           Int   @id @default(autoincrement())
  companyId    Int
  employeeId   Int
  employeeName String
  employeeCode String?
  department   String?
  branch       String?
  shift        String?
  date         String
  inTime       String
  outTime      String
  otHours      Float
  type         String
  reason       String?
  remarks      String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Shift {
  id           Int   @id @default(autoincrement())
  companyId    Int
  name         String
  code         String?
  start        String
  end          String
  grace        String?
  breakTime    String?
  otEnabled    Boolean  @default(false)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees    Employee[]
}

model LeaveRequest {
  id           Int   @id @default(autoincrement())
  companyId    Int
  employeeId   Int
  employeeName String
  department   String
  leaveType    String
  fromDate     String
  toDate       String
  days         Float
  reason       String
  status       String   @default("Pending")
  appliedOn    String
  approvedBy   String?
  approvedOn   String?
  paidDays     Float    @default(0)
  lwpDays      Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model LeaveCreditConfig {
  id           Int      @id @default(autoincrement())
  companyId    Int
  year         Int      @default(2026)
  startMonth   Int      @default(1)
  endMonth     Int      @default(12)
  clPerMonth   Float    @default(1)
  plPerMonth   Float    @default(1.5)
  slPerMonth   Float    @default(1)
  carryForward Float    @default(5)
  // ── Carry-forward & encashment policy ──
  carryForwardEnabled Boolean @default(true)
  maxCarryForward     Float   @default(5)
  allowEncashment     Boolean @default(false)
  encashableTypes     String  @default("PL")   // comma list of CL,PL,SL
  maxEncashmentDays   Float   @default(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year])
}

model LeaveBalance {
  id                  Int      @id @default(autoincrement())
  companyId           Int
  employeeId          Int
  year                Int      @default(2026)
  clBalance           Float    @default(0)
  plBalance           Float    @default(0)
  slBalance           Float    @default(0)
  clUsed              Float    @default(0)
  plUsed              Float    @default(0)
  slUsed              Float    @default(0)
  carryForward        Float    @default(0)
  accruedThroughMonth Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, year])
}

model AttendanceSummary {
  id          Int      @id @default(autoincrement())
  companyId   Int
  employeeId  Int
  month       String
  year        Int      @default(2026)
  presentDays Float    @default(0)
  absentDays  Float    @default(0)
  cl          Float    @default(0)
  pl          Float    @default(0)
  sl          Float    @default(0)
  lwp         Float    @default(0)
  halfDays    Float    @default(0)
  otHours     Float    @default(0)
  shift       String?
  payableDays Float    @default(0)
  locked      Boolean  @default(false)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
}

model Document {
  id           Int   @id @default(autoincrement())
  companyId    Int
  branchId     Int?                       // branch the document is scoped to (optional)
  name         String
  type         String
  employeeId   Int?
  employeeName String?
  uploadedBy   String
  uploadedOn   String
  size         String
  url          String?  @db.Text          // external link (Google Drive / OneDrive / Dropbox / direct PDF)
  fileData     String?  @db.LongText       // base64-encoded uploaded file (device / drag-drop / camera)
  mimeType     String?                     // MIME type of fileData, drives the preview viewer
  documentNumber String?                   // e.g. Aadhaar / PAN / passport number (optional)
  issueDate    String?                     // optional issue date (ISO yyyy-mm-dd)
  expiryDate   String?                     // optional expiry date — drives "Expiring Soon" / "Expired"
  remarks      String?  @db.Text           // upload / verification remarks
  verifiedBy   String?                     // audit: who verified/rejected
  verifiedOn   String?                     // audit: when verified/rejected
  editedBy     String?                     // audit: who last edited details
  editedOn     String?                     // audit: when last edited
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       String   @default("Pending")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id           Int   @id @default(autoincrement())
  companyId    Int
  companyName  String
  planName     String
  amount       Float
  billingCycle String
  status       String
  date         String
  invoiceUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int   @id @default(autoincrement())
  companyId Int?
  userId    Int?                       // target user (null = company/branch-wide)
  branchId  Int?
  type      String
  title     String?
  message   String
  timestamp String
  read      Boolean  @default(false)
  status    String   @default("unread") // unread / read
  priority  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
}

model AuditLog {
  id        Int   @id @default(autoincrement())
  userId    Int
  action    String
  module    String
  targetId  String
  details   String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SubscriptionPlan {
  id                  Int   @id @default(autoincrement())
  name                String
  priceMonthly        Float
  priceYearly         Float
  employeeLimit       Int
  hrLimit             Int
  storageLimit        String
  payrollAccess       Boolean
  documentAccess      Boolean
  includedBranchLimit Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Task Manager ─────────────────────────────────────────────────────────────
// Standalone tables (scalar foreign keys, no relations on existing models) so
// adding this module cannot alter or break any existing relationship.
model Task {
  id             Int      @id @default(autoincrement())
  title          String
  description    String?  @db.Text
  priority       String   @default("Medium")  // Low / Medium / High / Critical
  status         String   @default("Pending") // Pending / In Progress / Completed / Cancelled / Overdue
  startDate      String?
  dueDate        String?
  startTime      String?
  endTime        String?
  companyId      Int?
  branchId       Int?
  createdById    Int
  createdByName  String   @default("")
  createdByRole  String?
  assignmentType String   @default("user")    // user / multiple / department / branch / role
  assigneeIds    Json     @default(dbgenerated("(JSON_ARRAY())")) // [userId, ...]
  assigneeNames  Json     @default(dbgenerated("(JSON_ARRAY())")) // [name, ...]
  department     String?
  targetRole     String?
  mentions       Json     @default(dbgenerated("(JSON_ARRAY())")) // [username, ...]
  attachments    Json     @default(dbgenerated("(JSON_ARRAY())")) // [{name,type,url,size}]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([createdById])
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int?
  userName  String   @default("")
  message   String   @db.Text
  parentId  Int?     // set when this is a reply to another comment
  isStatus  Boolean  @default(false) // true for status-change system notes
  createdAt DateTime @default(now())

  @@index([taskId])
}

// ── Tender Information (future-ready; placeholder data for now) ───────────────
model Tender {
  id           Int      @id @default(autoincrement())
  tenderNumber String?
  tenderName   String
  department   String?
  tenderValue  Float    @default(0)
  publishDate  String?
  closingDate  String?
  status       String   @default("Upcoming") // Upcoming / Live / Closed
  documentPath String?
  category     String?  // Government / Private / HR Service / Recruitment / Vendor
  companyId    Int?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}
