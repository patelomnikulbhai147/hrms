generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE INFRASTRUCTURE
// ==========================================

model User {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  username             String   @unique
  passwordHash         String
  password             String?
  userId               String?
  role                 String   // e.g. "Super Admin", "Company Head", "HR"
  companyId            String?
  accessibleCompanyIds String[]
  status               String   @default("Active") // "Active", "Disabled"
  avatar               String?
  employeeId           String?
  
  // Minimal JSON to store modular access if needed
  permissions          Json?    
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  auditLogs            AuditLog[]
}

model Company {
  id                   String   @id @default(uuid())
  name                 String
  domain               String?
  adminName            String?
  adminEmail           String?
  phone                String?
  industry             String?
  
  // Statuses
  status               String   @default("Active")
  accountStatus        String   @default("Active")
  paymentStatus        String   @default("Paid")
  plan                 String   @default("Starter")
  
  employeeCount        Int      @default(0)
  joinDate             DateTime @default(now())
  
  logo                 String?
  logoImage            String?
  pfRate               Float?
  esicRate             Float?
  basicPercent         Float?
  overtimeRate         Float?
  profTaxRate          Float?
  primaryColor         String?
  themeStyle           String?
  
  headerText           String?
  footerText           String?
  signatureText        String?
  gstNumber            String?
  billingAddress       String?
  subscriptionPrice    Float?
  priceMonthly         Float?
  priceYearly          Float?
  billingCycle         String?
  branchName           String?
  branchCode           String?
  purchasedAdditionalBranches Int?
  branchLicenseStatus  String?
  branchRenewalDate    String?
  employeeCapacity     Int?
  payrollLoad          Float?
  storageUsed          String?
  activeHrUsers        Int?
  monthlyUsage         Float?
  branchPriceAddon     Float?
  branchLicenseActive  Boolean?
  branchPortalActive   Boolean?
  licensedEmployeeLimit Int?
  monthlyBranchCost    Float?
  billingIncluded      Boolean?
  companyIndustry      String?
  departmentTemplateType String?
  customDepartments    String[]
  inheritParentDepartments Boolean?
  
  // Hierarchy
  isHeadOffice         Boolean  @default(true)
  parentCompanyId      String?
  
  // Offboarding JSON state
  offboardingState     Json?
  
  isArchived           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  branches             Branch[]
  employees            Employee[]
  payrolls             Payroll[]
  attendances          Attendance[]
  leaveRequests        LeaveRequest[]
  documents            Document[]
  paymentRecords       PaymentRecord[]
}

model Branch {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  
  branchName           String
  location             String?
  headcount            Int      @default(0)
  status               String   @default("Active")
  isArchived           Boolean  @default(false)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  employees            Employee[]
}

// ==========================================
// WORKFORCE MANAGEMENT
// ==========================================

model Employee {
  id                   String   @id @default(uuid())
  employeeId           String   @unique // HRMS-generated ID
  
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  branchId             String?
  branch               Branch?  @relation(fields: [branchId], references: [id])
  
  name                 String
  firstName            String?
  lastName             String?
  email                String
  phone                String?
  department           String
  designation          String
  role                 String   @default("Staff") // "HR", "Finance", "Staff"
  status               String   @default("Active") // "Active", "Archived", "Terminated"
  
  joinDate             DateTime
  exitDate             DateTime?
  exitReason           String?
  
  location             String?
  avatar               String?
  salary               Float    @default(0)
  manager              String?
  
  // Compliance & IDs
  pan                  String?
  aadhaar              String?
  uan                  String?
  pfNumber             String?
  esiNumber            String?
  
  // Bank Details
  bankName             String?
  accountNumber        String?
  ifsc                 String?
  
  // Enterprise Details missing from DB previously
  middleName           String?
  aadhaarName          String?
  gender               String?
  dob                  String?
  maritalStatus        String?
  nationality          String?
  fatherSpouseName     String?
  relationType         String?
  emergencyContact     String?
  category             String?
  employmentType       String?
  serviceBookNo        String?
  branchLocation       String?
  presentAddress       String?
  permanentAddress     String?
  photoUpload          String?
  signatureUpload      String?
  aadhaarUpload        String?
  panUpload            String?
  
  // JSON field for workflow state
  offboardingState     Json?
  employmentHistory    Json?
  documents            Json?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  payroll              Payroll[]
  attendance           Attendance[]
  leaveRequests        LeaveRequest[]
}

model Payroll {
  id                   String   @id @default(uuid())
  companyId            String   @default("c-gcri")
  company              Company  @relation(fields: [companyId], references: [id])
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  employeeName         String   @default("Unknown")
  department           String   @default("General")
  month                String
  year                 Int      @default(2026)
  basicSalary          Float    @default(0)
  allowances           Float    @default(0)
  deductions           Float    @default(0)
  netSalary            Float    @default(0)
  payrollStatus        String   @default("draft")
  paymentStatus        String   @default("pending")
  payslipGenerated     Boolean  @default(false)
  processedOn          String?
  paymentDate          String?
  dueDate              String?
  paymentMethod        String?
  paidBy               String?
  bonus                Float?
  tax                  Float?
  notes                String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([employeeId, month, year, companyId])
}

model Attendance {
  id                   String   @id @default(uuid())
  companyId            String   @default("c-gcri")
  company              Company  @relation(fields: [companyId], references: [id])
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  employeeName         String   @default("Unknown")
  department           String   @default("General")
  date                 String   @default("2026-05-20")
  clockIn              String   @default("09:00")
  clockOut             String   @default("18:00")
  status               String   @default("Present")
  hoursWorked          Float    @default(8)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model LeaveRequest {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  employeeName         String
  department           String
  leaveType            String
  fromDate             String
  toDate               String
  days                 Float
  reason               String
  status               String   @default("Pending")
  appliedOn            String
  approvedBy           String?
  approvedOn           String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Document {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  name                 String
  type                 String
  employeeId           String?
  employeeName         String?
  uploadedBy           String
  uploadedOn           String
  size                 String
  url                  String?  
  status               String   @default("Pending")
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PaymentRecord {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  companyName          String
  planName             String
  amount               Float
  billingCycle         String
  status               String
  date                 String
  invoiceUrl           String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Notification {
  id                   String   @id @default(uuid())
  companyId            String?
  type                 String
  message              String
  timestamp            String
  read                 Boolean  @default(false)
  priority             String?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ==========================================
// SECURITY & AUDIT
// ==========================================

model AuditLog {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  
  action               String   // "CREATE", "UPDATE", "DELETE", "OFFBOARD"
  module               String   // "Employee", "Company", "Payroll"
  targetId             String
  details              String?  // JSON stringified summary of changes
  
  createdAt            DateTime @default(now())
}

model SubscriptionPlan {
  id String @id @default(uuid())
  name String
  priceMonthly Float
  priceYearly Float
  employeeLimit Int
  hrLimit Int
  storageLimit String
  payrollAccess Boolean
  documentAccess Boolean
  includedBranchLimit Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
