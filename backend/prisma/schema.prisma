generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid())
  name                 String
  email                String     @unique
  username             String     @unique
  passwordHash         String
  role                 String
  companyId            String?
  accessibleCompanyIds String[]
  status               String     @default("Active")
  avatar               String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  employeeId           String?
  permissions          Json?
  password             String?
  userId               String?
  auditLogs            AuditLog[]
}

model Company {
  id                          String           @id @default(uuid())
  name                        String
  domain                      String?
  adminName                   String?
  adminEmail                  String?
  phone                       String?
  industry                    String?
  status                      String           @default("Active")
  accountStatus               String           @default("Active")
  paymentStatus               String           @default("Paid")
  plan                        String           @default("Starter")
  employeeCount               Int              @default(0)
  joinDate                    DateTime         @default(now())
  logo                        String?
  logoImage                   String?
  isHeadOffice                Boolean          @default(true)
  parentCompanyId             String?
  offboardingState            Json?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  basicPercent                Float?
  esicRate                    Float?
  overtimeRate                Float?
  pfRate                      Float?
  primaryColor                String?
  profTaxRate                 Float?
  themeStyle                  String?
  activeHrUsers               Int?
  billingAddress              String?
  billingCycle                String?
  billingIncluded             Boolean?
  branchCode                  String?
  branchLicenseActive         Boolean?
  branchLicenseStatus         String?
  branchName                  String?
  branchPortalActive          Boolean?
  branchPriceAddon            Float?
  branchRenewalDate           String?
  companyIndustry             String?
  customDepartments           String[]
  departmentTemplateType      String?
  employeeCapacity            Int?
  footerText                  String?
  gstNumber                   String?
  headerText                  String?
  inheritParentDepartments    Boolean?
  licensedEmployeeLimit       Int?
  monthlyBranchCost           Float?
  monthlyUsage                Float?
  payrollLoad                 Float?
  priceMonthly                Float?
  priceYearly                 Float?
  purchasedAdditionalBranches Int?
  signatureText               String?
  storageUsed                 String?
  subscriptionPrice           Float?
  isArchived                  Boolean          @default(false)
  attendances                 Attendance[]
  branches                    Branch[]
  companyPayrolls             CompanyPayroll[]
  documents                   Document[]
  employees                   Employee[]
  leaveRequests               LeaveRequest[]
  paymentRecords              PaymentRecord[]
  payrolls                    Payroll[]
  overtimes                   Overtime[]
  shifts                      Shift[]
}

model Branch {
  id               String          @id @default(uuid())
  companyId        String
  branchName       String
  location         String?
  headcount        Int             @default(0)
  status           String          @default("Active")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isArchived       Boolean         @default(false)
  adminEmail       String?
  adminName        String?
  basicPercent     Float           @default(50)
  branchCode       String?
  email            String?
  employeeCapacity Int             @default(200)
  esicRate         Float           @default(3.25)
  overtimeRate     Float           @default(1.5)
  pfRate           Float           @default(12)
  phone            String?
  profTaxRate      Float           @default(200)
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchPayrolls   BranchPayroll[]
  employees        Employee[]
}

model Employee {
  id                String         @id @default(uuid())
  employeeId        String         @unique
  companyId         String
  branchId          String?
  name              String
  firstName         String?
  lastName          String?
  email             String
  phone             String?
  department        String
  designation       String
  role              String         @default("Staff")
  status            String         @default("Active")
  joinDate          DateTime
  exitDate          DateTime?
  exitReason        String?
  location          String?
  avatar            String?
  salary            Float          @default(0)
  manager           String?
  pan               String?
  aadhaar           String?
  uan               String?
  pfNumber          String?
  esiNumber         String?
  bankName          String?
  accountNumber     String?
  ifsc              String?
  offboardingState  Json?
  employmentHistory Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  documents         Json?
  aadhaarName       String?
  aadhaarUpload     String?
  branchLocation    String?
  category          String?
  dob               String?
  emergencyContact  String?
  employmentType    String?
  fatherSpouseName  String?
  gender            String?
  maritalStatus     String?
  middleName        String?
  nationality       String?
  panUpload         String?
  permanentAddress  String?
  photoUpload       String?
  presentAddress    String?
  relationType      String?
  serviceBookNo     String?
  signatureUpload   String?
  attendance        Attendance[]
  branch            Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaveRequests     LeaveRequest[]
  payroll           Payroll[]
  overtimes         Overtime[]
}

model Payroll {
  id               String   @id @default(uuid())
  companyId        String   @default("c-gcri")
  employeeId       String
  employeeName     String   @default("Unknown")
  department       String   @default("General")
  month            String
  year             Int      @default(2026)
  basicSalary      Float    @default(0)
  allowances       Float    @default(0)
  deductions       Float    @default(0)
  netSalary        Float    @default(0)
  payrollStatus    String   @default("draft")
  paymentStatus    String   @default("pending")
  payslipGenerated Boolean  @default(false)
  processedOn      String?
  paymentDate      String?
  dueDate          String?
  paymentMethod    String?
  paidBy           String?
  bonus            Float?
  tax              Float?
  notes            String?
  companyPayrollId String?
  branchPayrollId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year, companyId])
}

model CompanyPayroll {
  id                 String   @id @default(uuid())
  companyId          String
  payrollMonth       String   @map("payroll_month")
  payrollYear        Int      @map("payroll_year")
  totalEmployees     Int      @map("total_employees")
  processedEmployees Int      @map("processed_employees")
  pendingEmployees   Int      @map("pending_employees")
  totalAmount        Float    @map("total_amount")
  status             String   @default("Pending")
  generatedBy        String   @map("generated_by")
  generatedAt        DateTime @default(now()) @map("generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, payrollMonth, payrollYear])
}

model BranchPayroll {
  id                 String   @id @default(uuid())
  branchId           String   @map("branch_id")
  companyId          String   @map("company_id")
  payrollMonth       String   @map("payroll_month")
  payrollYear        Int      @map("payroll_year")
  totalEmployees     Int      @map("total_employees")
  processedEmployees Int      @map("processed_employees")
  pendingEmployees   Int      @map("pending_employees")
  totalAmount        Float    @map("total_amount")
  status             String   @default("Pending")
  generatedBy        String   @map("generated_by")
  generatedAt        DateTime @default(now()) @map("generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  branch             Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, payrollMonth, payrollYear])
}

model Attendance {
  id           String   @id @default(uuid())
  companyId    String   @default("c-gcri")
  employeeId   String
  employeeName String   @default("Unknown")
  department   String   @default("General")
  branch       String?
  date         String   @default("2026-05-20")
  clockIn      String   @default("09:00")
  clockOut     String   @default("18:00")
  status       String   @default("Present")
  hoursWorked  Float    @default(8)
  flags        String[] @default([])
  leaveType    String?
  shift        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Overtime {
  id           String   @id @default(uuid())
  companyId    String
  employeeId   String
  employeeName String
  employeeCode String?
  department   String?
  branch       String?
  shift        String?
  date         String
  inTime       String
  outTime      String
  otHours      Float
  type         String
  reason       String?
  remarks      String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Shift {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  code         String?
  start        String
  end          String
  grace        String?
  breakTime    String?
  otEnabled    Boolean  @default(false)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id           String   @id @default(uuid())
  companyId    String
  employeeId   String
  employeeName String
  department   String
  leaveType    String
  fromDate     String
  toDate       String
  days         Float
  reason       String
  status       String   @default("Pending")
  appliedOn    String
  approvedBy   String?
  approvedOn   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Document {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  type         String
  employeeId   String?
  employeeName String?
  uploadedBy   String
  uploadedOn   String
  size         String
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       String   @default("Pending")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id           String   @id @default(uuid())
  companyId    String
  companyName  String
  planName     String
  amount       Float
  billingCycle String
  status       String
  date         String
  invoiceUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  companyId String?
  type      String
  message   String
  timestamp String
  read      Boolean  @default(false)
  priority  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  module    String
  targetId  String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SubscriptionPlan {
  id                  String   @id @default(uuid())
  name                String
  priceMonthly        Float
  priceYearly         Float
  employeeLimit       Int
  hrLimit             Int
  storageLimit        String
  payrollAccess       Boolean
  documentAccess      Boolean
  includedBranchLimit Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
